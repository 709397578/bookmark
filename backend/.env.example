# PinTree Backend Configuration

# Server
PORT=8080

# Database Driver: "postgres" or "sqlite"
DB_DRIVER=postgres

# PostgreSQL connection string (used when DB_DRIVER=postgres)
DATABASE_URL=host=localhost user=postgres password=your_password dbname=pintree port=5432 sslmode=disable

# SQLite file path (used when DB_DRIVER=sqlite)
DB_PATH=./data/pintree.db

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=86400

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Upload Path
UPLOAD_PATH=./uploads

# Default Admin Account (auto-created if no admin exists)
ADMIN_EMAIL=admin@pintree.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=管理员
